rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    // Temporary bootstrap window so ingestion can run before Firebase Auth is wired.
    // Tighten this date or remove once auth-backed writes are ready.
    function isBootstrapWriteWindow() {
      return request.time < timestamp.date(2026, 8, 1);
    }

    // Public read app catalog data.
    match /breweries/{docId} {
      allow read: if true;
      allow create, update: if isBootstrapWriteWindow();
      allow delete: if false;
    }

    match /beers/{docId} {
      allow read: if true;
      allow create, update: if isBootstrapWriteWindow();
      allow delete: if false;
    }

    match /events/{docId} {
      allow read: if true;
      allow create, update: if isBootstrapWriteWindow();
      allow delete: if false;
    }

    match /foodTrucks/{docId} {
      allow read: if true;
      allow create, update: if isBootstrapWriteWindow();
      allow delete: if false;
    }

    match /foodTruckStops/{docId} {
      allow read: if true;
      allow create, update: if isBootstrapWriteWindow();
      allow delete: if false;
    }

    // User data locked to the authenticated user.
    match /users/{uid} {
      allow read, create, update: if isSignedIn() && request.auth.uid == uid;
      allow delete: if false;
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
